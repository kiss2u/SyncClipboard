<Window x:Class="SyncClipboard.Desktop.Views.HistoryWindow"
        xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:m="using:SyncClipboard.Core.Models"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="using:FluentAvalonia.UI.Controls"
        xmlns:views="using:SyncClipboard.Desktop.Views"
        xmlns:controls="using:SyncClipboard.Desktop.Controls"
        xmlns:vm="using:SyncClipboard.Core.ViewModels"
        xmlns:vms="using:SyncClipboard.Core.ViewModels.Sub"
        xmlns:local="using:SyncClipboard.Desktop.Views"
        xmlns:i18n="using:SyncClipboard.Core.I18n"
        xmlns:vc="using:SyncClipboard.Desktop.ValueConverters"
        xmlns:asyncImage="using:AsyncImageLoader"
        x:Name="_HistoryWindow"
        Title="{x:Static i18n:Strings.ClipboardHistory}"
        Width="850"
        Height="530"
        d:DesignHeight="450"
        d:DesignWidth="800"
        x:DataType="vm:HistoryViewModel"
        TransparencyLevelHint="AcrylicBlur"
        Background="Transparent"
        Icon="/Assets/icon.ico"
        WindowStartupLocation="CenterScreen"
        mc:Ignorable="d">
    <Window.Resources>
        <ResourceDictionary>
            <x:Double x:Key="TabItemMinHeight">38</x:Double>
            <Flyout x:Key="FontScaleFlyout">
                <StackPanel Orientation="Horizontal" Spacing="8" Margin="4">
                    <TextBlock VerticalAlignment="Center" />
                    <NumericUpDown Minimum="25"
                                   Maximum="400"
                                   Increment="5"
                                   FormatString="0"
                                   Width="130"
                                   ValueChanged="FontScaleNumericUpDown_ValueChanged" />
                    <TextBlock Text="%" VerticalAlignment="Center" />
                </StackPanel>
            </Flyout>
        </ResourceDictionary>
    </Window.Resources>
    <Window.KeyBindings>
        <KeyBinding Gesture="Ctrl+Home" Command="{Binding CtrlHomeCommand}" />
        <KeyBinding Gesture="Ctrl+End" Command="{Binding CtrlEndCommand}" />
    </Window.KeyBindings>
    <Window.DataTemplates>
        <local:ClipboardViewerTemplateSelector>
            <DataTemplate x:Key="Normal" DataType="vms:HistoryRecordVM">
                <TextBlock>
                    <TextBlock.Text>
                        <MultiBinding Converter="{x:Static vc:FuncConverter.LimitHistoryListText}">
                            <Binding Path="Text" />
                            <Binding Path="#_HistoryWindow.ViewModel.IsCompactListMode" />
                        </MultiBinding>
                    </TextBlock.Text>
                </TextBlock>
            </DataTemplate>
            <DataTemplate x:Key="Image" DataType="vms:HistoryRecordVM">
                <StackPanel Spacing="4" Orientation="Vertical">
                    <Image MaxHeight="202"
                           HorizontalAlignment="Left"
                           asyncImage:ImageLoader.Source="{Binding PreviewImage}"
                           Stretch="None"
                           DoubleTapped="Image_DoubleTapped"
                           Opacity="0"
                           Loaded="Image_Loaded"
                           IsVisible="{Binding #_HistoryWindow.ViewModel.IsCompactListMode, Converter={x:Static vc:FuncConverter.Not}}" />
                    <TextBlock HorizontalAlignment="Left">
                        <TextBlock.Text>
                            <MultiBinding Converter="{x:Static vc:FuncConverter.LimitHistoryListText}">
                                <Binding Path="Text" />
                                <Binding Path="#_HistoryWindow.ViewModel.IsCompactListMode" />
                            </MultiBinding>
                        </TextBlock.Text>
                    </TextBlock>
                </StackPanel>
            </DataTemplate>
        </local:ClipboardViewerTemplateSelector>
    </Window.DataTemplates>
    <Panel>
        <Panel.Styles>
            <Style Selector="Button">
                <Setter Property="Theme" Value="{StaticResource DateTimeFlyoutButtonStyle}" />
                <Setter Property="Height" Value="28" />
                <Setter Property="Width" Value="28" />
                <Setter Property="FontSize" Value="14" />
                <Setter Property="Focusable" Value="False" />
            </Style>
            <Style Selector="ToggleButton">
                <Setter Property="Focusable" Value="False" />
            </Style>
            <Style Selector="ListBoxItem">
                <Setter Property="Focusable" Value="False" />
            </Style>
            <Style Selector="TabStripItem">
                <Setter Property="Focusable" Value="False" />
            </Style>
        </Panel.Styles>
        <ExperimentalAcrylicBorder IsHitTestVisible="False">
            <ExperimentalAcrylicBorder.Material>
                <ExperimentalAcrylicMaterial BackgroundSource="Digger"
                                             TintColor="{DynamicResource WindowBackgroudColor}"
                                             TintOpacity="1"
                                             FallbackColor="{DynamicResource WindowBackgroudColor}"
                                             MaterialOpacity="0.65" />
            </ExperimentalAcrylicBorder.Material>
        </ExperimentalAcrylicBorder>
        <Grid RowDefinitions="Auto, Auto, *">
            <TabStrip x:Name="_FilterSelectorBar"
                      HorizontalAlignment="Center"
                      ItemsSource="{Binding FilterOptions}"
                      SelectedItem="{Binding SelectedFilterOption}"
                      IsTabStop="False"
                      Focusable="False">
                <TabStrip.ItemTemplate>
                    <DataTemplate x:DataType="{x:Type m:LocaleString, x:TypeArguments=vms:HistoryFilterType}">
                        <TextBlock Text="{Binding ShownString}" FontSize="14" />
                    </DataTemplate>
                </TabStrip.ItemTemplate>
            </TabStrip>
            <StackPanel x:Name="_ButtonArea"
                        Margin="0,2,8,0"
                        HorizontalAlignment="Right"
                        Orientation="Horizontal"
                        Spacing="4">
                <ToggleButton ToolTip.Tip="{x:Static i18n:Strings.WindowTopmost}" Classes="FontIcon" IsChecked="{Binding IsTopmost, Mode=TwoWay}">
                    <ui:FontIcon Glyph="&#xE840;" FontFamily="{StaticResource SymbolThemeFontFamily}" />
                </ToggleButton>
                <ToggleButton ToolTip.Tip="{x:Static i18n:Strings.OnlyShowStarred}" Classes="FontIcon" IsChecked="{Binding OnlyShowStarred, Mode=TwoWay}">
                    <ui:FontIcon Glyph="&#xE734;" FontFamily="{StaticResource SymbolThemeFontFamily}" />
                </ToggleButton>
                <ToggleButton ToolTip.Tip="{x:Static i18n:Strings.PreviewPanel}" Classes="FontIcon" IsChecked="{Binding ShowPreviewPanel, Mode=TwoWay}">
                    <ui:FontIcon Glyph="&#xE145;" FontFamily="{StaticResource SymbolThemeFontFamily}" />
                </ToggleButton>
                <Button x:Name="_MenuButton"
                        Width="24"
                        Height="24"
                        VerticalAlignment="Center">
                    <ui:FontIcon Glyph="&#xE10C;" FontFamily="{StaticResource SymbolThemeFontFamily}" />
                    <Button.Flyout>
                        <ui:FAMenuFlyout>
                            <ui:ToggleMenuFlyoutItem Text="{x:Static i18n:Strings.ScrollToTopOnReopen}" IsChecked="{Binding ScrollToTopOnReopen, Mode=TwoWay}" />
                            <ui:ToggleMenuFlyoutItem Text="{x:Static i18n:Strings.CloseHistoryWindowWhenLostFocus}" IsChecked="{Binding CloseWhenLostFocus, Mode=TwoWay}" />
                            <ui:MenuFlyoutSeparator />
                            <ui:ToggleMenuFlyoutItem Text="{x:Static i18n:Strings.ShowSyncStatus}" IsChecked="{Binding ShowSyncState, Mode=TwoWay}" />
                            <ui:ToggleMenuFlyoutItem Text="{x:Static i18n:Strings.ShowStarredFilter}" IsChecked="{Binding ShowStarredFilter, Mode=TwoWay}" />
                            <!--<ui:ToggleMenuFlyoutItem Text="{x:Static i18n:Strings.OnlyShowLocal}" IsChecked="{Binding OnlyShowLocal, Mode=TwoWay}" />-->
                            <ui:ToggleMenuFlyoutItem Text="{x:Static i18n:Strings.SortByLastAccessed}" IsChecked="{Binding SortByLastAccessed, Mode=TwoWay}" />
                            <ui:ToggleMenuFlyoutItem Text="{x:Static i18n:Strings.CompactListWhenPreview}" IsChecked="{Binding CompactListWhenPreview, Mode=TwoWay}" />
                            <ui:MenuFlyoutSeparator />
                            <ui:ToggleMenuFlyoutItem Text="{x:Static i18n:Strings.FollowCaretPosition}" IsChecked="{Binding FollowCaretPosition, Mode=TwoWay}" />
                            <ui:ToggleMenuFlyoutItem Text="{x:Static i18n:Strings.FollowForegroundWindowScreen}" IsChecked="{Binding FollowForegroundWindowScreen, Mode=TwoWay}" />
                            <ui:ToggleMenuFlyoutItem Text="{x:Static i18n:Strings.FollowMousePosition}" IsChecked="{Binding FollowMousePosition, Mode=TwoWay}" />
                            <ui:MenuFlyoutSeparator />
                            <ui:MenuFlyoutItem Text="{x:Static i18n:Strings.FontScale}" Click="FontScaleMenuItem_Click" />
                        </ui:FAMenuFlyout>
                    </Button.Flyout>
                </Button>
                <OnPlatform>
                    <OnPlatform.Windows>
                        <Button Width="24"
                                Height="24"
                                VerticalAlignment="Center"
                                Command="{Binding CloseCommand}">
                            <ui:FontIcon Glyph="&#xE711;" FontFamily="{StaticResource SymbolThemeFontFamily}" />
                        </Button>
                    </OnPlatform.Windows>
                    <OnPlatform.Default>
                        <Border Width="0" Height="0" />
                    </OnPlatform.Default>
                </OnPlatform>
            </StackPanel>
            <Grid Grid.Row="1" Margin="20,8,8,8" ColumnDefinitions="*, Auto">
                <TextBox x:Name="_SearchTextBox"
                         Grid.Column="0"
                         VerticalContentAlignment="Center"
                         Text="{Binding SearchText}"
                         Watermark="{x:Static i18n:Strings.HistorySearchPlaceholder}" />
                <StackPanel Grid.Column="1" VerticalAlignment="Top" Orientation="Horizontal">
                    <Button Width="32"
                            Height="32"
                            Command="{Binding RefreshCommand}"
                            ToolTip.Tip="{x:Static i18n:Strings.Refresh}">
                        <Grid>
                            <ui:FontIcon Glyph="&#xE72C;" FontFamily="{StaticResource SymbolThemeFontFamily}" IsVisible="{Binding !IsLoading}" />
                            <ui:ProgressRing Width="16"
                                             Height="16"
                                             HorizontalAlignment="Center"
                                             VerticalAlignment="Center"
                                             IsActive="{Binding IsLoading}"
                                             IsVisible="{Binding IsLoading}" />
                        </Grid>
                    </Button>
                    <Button Width="32"
                            Height="32"
                            Command="{Binding ScrollToTopCommand}"
                            ToolTip.Tip="{x:Static i18n:Strings.ScrollToTop}">
                        <ui:FontIcon Glyph="&#xE898;" FontFamily="{StaticResource SymbolThemeFontFamily}" />
                    </Button>
                </StackPanel>
            </Grid>
            <Image x:Name="_InvisualableImage"
                   Grid.Row="2"
                   MaxHeight="800"
                   Stretch="None"
                   IsHitTestVisible="False"
                   Opacity="0" />
            <Grid x:Name="_MainContentGrid" Grid.Row="2" ColumnDefinitions="Auto, Auto, Auto">
                <ListBox x:Name="_ListBox"
                         Grid.Column="0"
                         ItemsSource="{Binding HistoryItems}"
                         SelectionMode="Single"
                         SelectedIndex="{Binding SelectedIndex}"
                         DoubleTapped="ListBox_DoubleTapped"
                         HorizontalAlignment="Stretch">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel />
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="vms:HistoryRecordVM">
                            <Grid MinHeight="10"
                                  ColumnDefinitions="Auto, *, Auto, Auto"
                                  Background="Transparent"
                                  Opacity="{Binding SyncState, Converter={x:Static vc:FuncConverter.SyncStateToOpacity}}"
                                  PointerPressed="Grid_PointerPressed"
                                  PointerMoved="Grid_PointerMoved"
                                  PointerReleased="Grid_PointerReleased"
                                  IsHitTestVisible="True">
                                <Grid.ContextFlyout>
                                    <ui:FAMenuFlyout Opening="ItemContextFlyout_Opening" />
                                </Grid.ContextFlyout>
                                <Border Grid.Column="0"
                                        Height="40"
                                        Margin="0,0,0,0"
                                        VerticalAlignment="Top">
                                    <Path Width="14"
                                          Height="14"
                                          VerticalAlignment="Center"
                                          Stretch="Uniform"
                                          Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ListBoxItem}}"
                                          StrokeLineCap="Round"
                                          StrokeJoin="Round"
                                          StrokeThickness="1">
                                        <Path.Data>
                                            <MultiBinding Converter="{x:Static vc:FuncConverter.HistoryRecordToHugeiconsGeometry}">
                                                <Binding Path="Type" />
                                                <Binding Path="FilePath" />
                                            </MultiBinding>
                                        </Path.Data>
                                    </Path>
                                </Border>
                                <StackPanel Grid.Column="1" Orientation="Vertical" VerticalAlignment="Center">
                                    <ContentControl Padding="8,8,0,8"
                                                    VerticalAlignment="Center"
                                                    FontSize="{Binding #_HistoryWindow.ViewModel.ListItemFontSize}"
                                                    Content="{Binding .}" />
                                </StackPanel>
                                <Border Grid.Column="2"
                                        Height="40"
                                        VerticalAlignment="Top"
                                        Padding="12,0,0,0">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="2">
                                        <TextBlock Text="{Binding RelativeTime}"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,8,0"
                                                   Opacity="0.6"
                                                   FontSize="12"
                                                   ToolTip.Tip="{Binding FullDateTime}" />
                                        <!--  Control buttons - hidden when preview panel is open  -->
                                        <views:RecordControlBar IsVisible="{Binding !#_HistoryWindow.ViewModel.ShowPreviewPanel}" Record="{Binding .}" ViewModel="{Binding #_HistoryWindow.ViewModel}" />
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="3"
                                        Width="2"
                                        Margin="4,0,4,0"
                                        Background="{Binding SyncState, Converter={x:Static vc:FuncConverter.SyncStateToBrush}}"
                                        ToolTip.Tip="{Binding SyncState, Converter={x:Static vc:FuncConverter.SyncStateToText}}">
                                    <Border.IsVisible>
                                        <MultiBinding Converter="{x:Static vc:FuncConverter.ShowSyncStatusIndicator}">
                                            <Binding Path="ViewModel.ShowSyncState" RelativeSource="{RelativeSource AncestorType=views:HistoryWindow}" />
                                            <Binding Path="ViewModel.ShowPreviewPanel" RelativeSource="{RelativeSource AncestorType=views:HistoryWindow}" />
                                        </MultiBinding>
                                    </Border.IsVisible>
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
                <Border x:Name="_PreviewSplitter"
                        Grid.Column="1"
                        Width="1"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Stretch"
                        Background="LightGray"
                        IsVisible="{Binding ShowPreviewPanel}"
                        Cursor="SizeWestEast"
                        PointerEntered="PreviewSplitter_PointerEntered"
                        PointerExited="PreviewSplitter_PointerExited"
                        PointerPressed="PreviewSplitter_PointerPressed"
                        PointerMoved="PreviewSplitter_PointerMoved"
                        PointerReleased="PreviewSplitter_PointerReleased" />
                <controls:PreviewPanel x:Name="_PreviewPanel"
                                       Grid.Column="2"
                                       IsVisible="{Binding ShowPreviewPanel}"
                                       ViewModel="{Binding $parent[Window].DataContext, x:DataType=vm:HistoryViewModel}"
                                       SelectedItem="{Binding #_ListBox.SelectedItem}" />
            </Grid>
            <ui:InfoBar x:Name="_InfoBar"
                        Grid.Row="2"
                        Width="400"
                        Margin="{Binding #_ListBox.Bounds.Height, Converter={x:Static vc:FuncConverter.CalculateInfoBarMargin}}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Bottom"
                        IsOpen="{Binding ShowInfoBar}"
                        Message="{Binding InfoBarMessage}"
                        Severity="Warning"
                        IsClosable="True" />
        </Grid>
    </Panel>
</Window>
