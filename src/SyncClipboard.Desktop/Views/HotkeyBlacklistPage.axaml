<UserControl x:Class="SyncClipboard.Desktop.Views.HotkeyBlacklistPage"
             xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:i18n="using:SyncClipboard.Core.I18n"
             xmlns:ui="using:FluentAvalonia.UI.Controls"
             xmlns:vm="using:SyncClipboard.Core.ViewModels"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             x:DataType="vm:HotkeyBlacklistViewModel"
             mc:Ignorable="d">
    <Grid RowDefinitions="Auto,Auto,*" RowSpacing="10">
        <ui:SettingsExpander Header="全局快捷键例外程序" Description="{x:Static i18n:Strings.ClipboardOwnerFilterDescription}" IsExpanded="True">
            <ui:SettingsExpander.IconSource>
                <ui:FontIconSource Glyph="&#xE8A7;" FontFamily="{StaticResource SymbolThemeFontFamily}" />
            </ui:SettingsExpander.IconSource>
            <ui:SettingsExpander.Footer>
                <ToggleSwitch OnContent="{x:Static i18n:Strings.On}" OffContent="{x:Static i18n:Strings.Off}" IsChecked="{Binding IsEnabled, Mode=TwoWay}" />
            </ui:SettingsExpander.Footer>
        </ui:SettingsExpander>
        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8">
            <Button Click="AddItemClick" Content="添加程序" />
            <Button Click="CaptureClick" Content="使用快捷键捕获" IsVisible="{Binding !IsCapturing}" />
            <Button Click="StopCaptureClick" Content="{x:Static i18n:Strings.Cancel}" IsVisible="{Binding IsCapturing}" />
            <TextBlock VerticalAlignment="Center"
                       Foreground="{DynamicResource SystemAccentColor}"
                       IsVisible="{Binding IsCapturing}"
                       Text="{Binding CaptureHint}" />
            <TextBlock VerticalAlignment="Center"
                       Foreground="OrangeRed"
                       IsVisible="{Binding IsSystemHotkeysSuspended}"
                       Text="全局快捷键已暂停" />
        </StackPanel>
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <Border Padding="12,8"
                        Background="{DynamicResource CardBackgroundFillColorSecondaryBrush}"
                        BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="8,8,0,0">
                    <Grid ColumnDefinitions="1*,1*,1*,80">
                        <TextBlock FontWeight="SemiBold" Text="进程名" />
                        <TextBlock Grid.Column="1" FontWeight="SemiBold" Text="窗口标题" />
                        <TextBlock Grid.Column="2" FontWeight="SemiBold" Text="可执行文件" />
                        <TextBlock Grid.Column="3"
                                   HorizontalAlignment="Center"
                                   FontWeight="SemiBold"
                                   Text="操作" />
                    </Grid>
                </Border>
                <ItemsControl ItemsSource="{Binding BlackList}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:EditableWindowInfo">
                            <Border Padding="12,8"
                                    Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1,0,1,1">
                                <Grid ColumnDefinitions="1*,1*,1*,80">
                                    <TextBlock VerticalAlignment="Center" Text="{Binding ProcessName}" TextWrapping="Wrap" />
                                    <TextBlock Grid.Column="1"
                                               VerticalAlignment="Center"
                                               Text="{Binding WindowTitle}"
                                               TextWrapping="Wrap" />
                                    <TextBlock Grid.Column="2"
                                               VerticalAlignment="Center"
                                               Text="{Binding ExecutableName}"
                                               TextWrapping="Wrap" />
                                    <StackPanel Grid.Column="3"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Orientation="Horizontal"
                                                Spacing="4">
                                        <Button Width="32"
                                                Height="32"
                                                Padding="0"
                                                Click="EditItemClick"
                                                DataContext="{Binding}">
                                            <TextBlock FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="14" Text="&#xE70F;" />
                                        </Button>
                                        <Button Width="32"
                                                Height="32"
                                                Padding="0"
                                                Click="DeleteItemClick"
                                                DataContext="{Binding}">
                                            <TextBlock FontFamily="{StaticResource SymbolThemeFontFamily}" FontSize="14" Text="&#xE74D;" />
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
