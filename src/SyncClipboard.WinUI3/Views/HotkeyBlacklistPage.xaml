<Page x:Class="SyncClipboard.WinUI3.Views.HotkeyBlacklistPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:local="using:SyncClipboard.WinUI3.Views"
      xmlns:i18n="using:SyncClipboard.Core.I18n"
      xmlns:ui="using:CommunityToolkit.WinUI.Controls"
      xmlns:vm="using:SyncClipboard.Core.ViewModels"
      xmlns:vc="using:SyncClipboard.WinUI3.ValueConverters">
    <Grid RowDefinitions="Auto,Auto,*" RowSpacing="10">
        <ui:SettingsCard Header="全局快捷键例外程序" Description="{x:Bind i18n:Strings.ClipboardOwnerFilterDescription}">
            <ToggleSwitch IsOn="{x:Bind _viewModel.IsEnabled, Mode=TwoWay}" />
        </ui:SettingsCard>
        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8">
            <Button Click="AddItemClick" Content="添加程序" />
            <Button Click="CaptureClick" Content="使用快捷键捕获" Visibility="{x:Bind vc:ConvertMethod.BoolToVisibilityNegate(_viewModel.IsCapturing), Mode=OneWay}" />
            <Button Click="StopCaptureClick" Content="{x:Bind i18n:Strings.Cancel}" Visibility="{x:Bind vc:ConvertMethod.BoolToVisibility(_viewModel.IsCapturing), Mode=OneWay}" />
            <TextBlock VerticalAlignment="Center"
                       Foreground="{ThemeResource SystemAccentColor}"
                       Text="{x:Bind _viewModel.CaptureHint, Mode=OneWay}"
                       Visibility="{x:Bind vc:ConvertMethod.BoolToVisibility(_viewModel.IsCapturing), Mode=OneWay}" />
            <TextBlock VerticalAlignment="Center"
                       Foreground="OrangeRed"
                       Text="全局快捷键已暂停"
                       Visibility="{x:Bind vc:ConvertMethod.BoolToVisibility(_viewModel.IsSystemHotkeysSuspended), Mode=OneWay}" />
        </StackPanel>
        <ScrollViewer Grid.Row="2" VerticalScrollMode="Enabled" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <Grid Padding="12,8"
                      Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                      BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                      BorderThickness="1"
                      CornerRadius="8,8,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1*" />
                        <ColumnDefinition Width="1*" />
                        <ColumnDefinition Width="1*" />
                        <ColumnDefinition Width="80" />
                    </Grid.ColumnDefinitions>
                    <TextBlock FontWeight="SemiBold" Text="进程名" />
                    <TextBlock Grid.Column="1" FontWeight="SemiBold" Text="窗口标题" />
                    <TextBlock Grid.Column="2" FontWeight="SemiBold" Text="可执行文件" />
                    <TextBlock Grid.Column="3"
                               HorizontalAlignment="Center"
                               FontWeight="SemiBold"
                               Text="操作" />
                </Grid>
                <ItemsControl ItemsSource="{x:Bind _viewModel.BlackList, Mode=OneWay}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:EditableWindowInfo">
                            <Grid Padding="12,8"
                                  Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                  BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                  BorderThickness="1,0,1,1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1*" />
                                    <ColumnDefinition Width="1*" />
                                    <ColumnDefinition Width="1*" />
                                    <ColumnDefinition Width="80" />
                                </Grid.ColumnDefinitions>
                                <TextBlock VerticalAlignment="Center" Text="{Binding ProcessName}" TextWrapping="Wrap" />
                                <TextBlock Grid.Column="1"
                                           VerticalAlignment="Center"
                                           Text="{Binding WindowTitle}"
                                           TextWrapping="Wrap" />
                                <TextBlock Grid.Column="2"
                                           VerticalAlignment="Center"
                                           Text="{Binding ExecutableName}"
                                           TextWrapping="Wrap" />
                                <StackPanel Grid.Column="3"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center"
                                            Orientation="Horizontal"
                                            Spacing="4">
                                    <Button Click="EditItemClick"
                                            DataContext="{Binding}"
                                            Width="32"
                                            Height="32"
                                            Padding="0">
                                        <FontIcon Glyph="&#xE70F;" FontSize="14" />
                                    </Button>
                                    <Button Click="DeleteItemClick"
                                            DataContext="{Binding}"
                                            Width="32"
                                            Height="32"
                                            Padding="0">
                                        <FontIcon Glyph="&#xE74D;" FontSize="14" />
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
